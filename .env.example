# mediaman bootstrap configuration
# Copy this file to .env and edit. Do NOT commit .env.

# REQUIRED: Master secret for encryption and token signing. Must be strong
# (>=64 hex chars or >=43 URL-safe base64 chars). The placeholder below is
# intentionally short and repetitive so it fails the startup entropy check
# — you MUST replace it with a real value before starting the app.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
MEDIAMAN_SECRET_KEY=REPLACE_THIS_NOW

# OPTIONAL: Web server port (default 8282)
MEDIAMAN_PORT=8282

# OPTIONAL: Host address uvicorn binds to.
#
# Leave this commented out for the standard Docker deployment — docker-compose.yml
# falls through to 0.0.0.0 (the only address reachable via the published port
# from the host). Setting MEDIAMAN_BIND_HOST=127.0.0.1 inside a container makes
# the service unreachable from the host.
#
# Bare-metal users who want localhost-only binding can uncomment the line below.
#MEDIAMAN_BIND_HOST=127.0.0.1

# OPTIONAL: Data directory for the SQLite database (default /data)
MEDIAMAN_DATA_DIR=/data

# OPTIONAL: Timezone for the scheduler (default UTC). Any IANA name.
TZ=UTC

# OPTIONAL: Comma-separated list of trusted reverse-proxy IPs.
# Required if behind a reverse proxy that sets X-Forwarded-For / X-Forwarded-Proto.
# Example: MEDIAMAN_TRUSTED_PROXIES=10.0.0.1,10.0.0.2
MEDIAMAN_TRUSTED_PROXIES=

# REQUIRED for deletion to work: colon-separated list of filesystem roots
# inside which mediaman is permitted to delete files (PATH-style).
# mediaman refuses deletion if unset. Inside the container, media is
# typically mounted at /media.
#
# Canonical separator is ':' — e.g. MEDIAMAN_DELETE_ROOTS=/media:/media2
# Legacy ',' separator is still accepted but deprecated; a warning is
# logged when it is used. Do not mix separators.
# Example: MEDIAMAN_DELETE_ROOTS=/media
MEDIAMAN_DELETE_ROOTS=
